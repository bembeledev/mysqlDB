fn verificar_paridade(n: int) {
    if (n % 2 == 0) {
        println(n, " é PAR");
    } else {
        println(n, " é ÍMPAR");
    }
}

for (var i: int = 1; i <= 5; i = i + 1) {
    verificar_paridade(i);
}



fn fatorial(n: int) -> int {
    if (n <= 1) {
        return 1;
    }
    return n * fatorial(n - 1);
}

println("Fatorial de 5 (120): ", fatorial(5));

